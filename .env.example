# ── Supabase PostgreSQL ───────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL (port 6543) for best Railway compatibility:
# postgresql://postgres.YOURREF:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.YOURREF:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Security ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────
# Set this to your Vercel URL first, then to app.goldencrescent.ae after DNS setup
FRONTEND_URL=https://app.goldencrescent.ae

# ══════════════════════════════════════════════════════════════
# GCD Backend — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL (Supabase Transaction Pooler) ──────────────────
# Supabase → Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── JWT Secret (REQUIRED — min 32 chars) ─────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_96_CHAR_HEX_STRING

# ── Supabase (for vehicle photo storage) ─────────────────────
# Supabase → Settings → API → service_role key (keep this secret!)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key — NEVER expose to frontend

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.goldencrescent.ae

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Seed (only needed when running seed script locally) ───────
# SEED_ADMIN_PASSWORD=<min 10 chars>
# SEED_POC_PASSWORD=<min 10 chars>
